{
  "boardLabel": "M365 Demo",
  "boardSubtitle": "WorkIQ and Foundry starter board",
  "cards": [
    {
      "id": "card-workiq-priorities",
      "meta": {
        "title": "M365 Priorities",
        "tags": [
          "workiq",
          "m365"
        ],
        "desc": "WorkIQ brief of the highest-priority signals across email, meetings, chats, and tasks."
      },
      "requires": [],
      "source_defs": [
        {
          "bindTo": "brief",
          "outputFile": "card-workiq-priorities.md",
          "projections": {
            "period": "card_data.period"
          },
          "mcp": {
            "server": "workiq",
            "tool": "workiq.ask",
            "input": {
              "query": "Summarize the highest-priority things I should pay attention to in {{period}} across my email, meetings, chats, and tasks. Return concise markdown with at most 5 bullets and one short watch-out line. No heading."
            }
          }
        }
      ],
      "compute": [
        {
          "bindTo": "briefMarkdown",
          "expr": "fetched_sources.brief ? fetched_sources.brief : '_Refresh to generate a WorkIQ brief._'"
        }
      ],
      "provides": [],
      "view": {
        "elements": [
          {
            "kind": "form",
            "label": "Time Horizon",
            "data": {
              "writeTo": "card_data",
              "saveLabel": "Apply",
              "discardLabel": "Reset",
              "fields": {
                "type": "object",
                "properties": {
                  "period": {
                    "type": "string",
                    "title": "Period"
                  }
                },
                "required": [
                  "period"
                ]
              }
            }
          },
          {
            "kind": "markdown",
            "label": "Priority Brief",
            "data": {
              "bind": "computed_values.briefMarkdown"
            }
          }
        ],
        "layout": {
          "board": {
            "col": 6,
            "order": 21
          },
          "canvas": {
            "x": 50,
            "y": 900,
            "w": 520,
            "h": 380
          }
        },
        "features": {
          "refresh": true
        }
      },
      "card_data": {
        "period": "today"
      }
    },
    {
      "id": "card-workiq-collaboration-radar",
      "meta": {
        "title": "Collaboration Radar",
        "tags": [
          "workiq",
          "m365"
        ],
        "desc": "WorkIQ view of the people and threads that mattered most recently."
      },
      "requires": [],
      "source_defs": [
        {
          "bindTo": "radar",
          "outputFile": "card-workiq-collaboration-radar.md",
          "projections": {
            "period": "card_data.period"
          },
          "mcp": {
            "server": "workiq",
            "tool": "workiq.ask",
            "input": {
              "query": "Who are the people I collaborated with the most in {{period}} across email, meetings, and chats? Return a concise markdown table with columns Person, Why they matter, Suggested follow-up. No heading."
            }
          }
        }
      ],
      "compute": [
        {
          "bindTo": "radarMarkdown",
          "expr": "fetched_sources.radar ? fetched_sources.radar : '_Refresh to generate a WorkIQ collaboration radar._'"
        }
      ],
      "provides": [],
      "view": {
        "elements": [
          {
            "kind": "form",
            "label": "Lookback Window",
            "data": {
              "writeTo": "card_data",
              "saveLabel": "Apply",
              "discardLabel": "Reset",
              "fields": {
                "type": "object",
                "properties": {
                  "period": {
                    "type": "string",
                    "title": "Period"
                  }
                },
                "required": [
                  "period"
                ]
              }
            }
          },
          {
            "kind": "markdown",
            "label": "Top Collaborators",
            "data": {
              "bind": "computed_values.radarMarkdown"
            }
          }
        ],
        "layout": {
          "board": {
            "col": 6,
            "order": 22
          },
          "canvas": {
            "x": 620,
            "y": 900,
            "w": 520,
            "h": 420
          }
        },
        "features": {
          "refresh": true
        }
      },
      "card_data": {
        "period": "the last 7 days"
      }
    },
    {
      "id": "card-foundry-brief",
      "meta": {
        "title": "AI Brief",
        "tags": [
          "foundry",
          "ai",
          "live"
        ],
        "desc": "Generates a concise AI brief for any portfolio or market topic using Azure AI Foundry."
      },
      "requires": [],
      "source_defs": [
        {
          "bindTo": "ai_brief",
          "outputFile": "card-foundry-brief.json",
          "projections": {
            "query": "card_data.query"
          },
          "foundry": {
            "prompt_template": "{{query}}\n\nRespond concisely. Plain text or short markdown only, no headers. Max 200 words."
          }
        }
      ],
      "compute": [
        {
          "bindTo": "brief_text",
          "expr": "fetched_sources.ai_brief ? fetched_sources.ai_brief : '_Hit refresh to generate the brief._'"
        }
      ],
      "view": {
        "elements": [
          {
            "kind": "form",
            "label": "Topic",
            "data": {
              "writeTo": "card_data",
              "saveLabel": "Apply",
              "discardLabel": "Reset",
              "fields": {
                "type": "object",
                "properties": {
                  "query": {
                    "type": "string",
                    "title": "Question or topic"
                  }
                },
                "required": [
                  "query"
                ]
              }
            }
          },
          {
            "kind": "markdown",
            "label": "Brief",
            "data": {
              "bind": "computed_values.brief_text"
            }
          }
        ],
        "layout": {
          "board": {
            "col": 6,
            "order": 20
          },
          "canvas": {
            "x": 1200,
            "y": 900,
            "w": 520,
            "h": 380
          }
        },
        "features": {
          "refresh": true
        }
      },
      "card_data": {
        "query": "Give a brief summary of current market themes to watch for an equity portfolio investor."
      }
    }
  ]
}